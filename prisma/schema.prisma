generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY
  MEMBER
}

enum ProfileSection {
  BASIC
  FINANCIAL
  STRATEGY
  HR
  CONTACT
}

enum ProjectMode {
  SINGLE
  STEP
}

enum ProjectStatus {
  WAITING_FOR_FORM
  ANALYSIS_PENDING
  REVIEWING
  CHAT_MODE
  RISK_ANALYSIS
  FINAL_ANALYSIS
}

enum StepSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FeedbackStatus {
  PENDING   
  REVIEWED   
}

enum NotificationType {
  ADMIN_FEEDBACK     
  PROJECT_RATED      
  PROJECT_ACCESS_GRANTED      
}

enum QuestionType {
  CHECKBOX
  RADIO
  DROPDOWN
  TEXT
  TEXTAREA
  NUMBER
}

model User {
  id               String   @id @default(uuid())
  avatar           String?
  username         String   @unique
  password         String
  email            String?  @unique
  phoneNumber      String?  @unique
  role             Role
  companyId        String?
  profile          Json?
  progress         Json?  

  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company         Company?      @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: Cascade)
  createdProjects Project[]
  stepSessions    StepSession[]
  ratingHistory   ProjectRatingHistory[]
  profileViewAccesses ProfileViewAccess[]
  chatMessages        ChatMessage[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  feedbackRequests    ProjectFeedbackRequest[]
  projectAccesses   ProjectAccess[] 
  @@index([role])
  @@index([companyId])
}

model ProfileViewAccess {
  id        String         @id @default(uuid())
  userId    String
  companyId String
  section   ProfileSection
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([userId, section])
  @@index([companyId])
}

model Company {
  id                  String              @id @default(uuid())
  name                String              @unique
  industry            String?
  profile             Json? // پروفایل شرکت
    progress         Json?  

  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userLimit           Int                 @default(1)
  members             User[]              @relation("CompanyMembers")
  projects            Project[]
  profileViewAccesses ProfileViewAccess[]
  adminData           CompanyAdminData?
  profileCompleted Boolean @default(false)
  @@index([id])
}

model CompanyAdminData {
  id        String   @id @default(uuid())
  companyId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Project {
  id String @id @default(uuid())
  title String
  creatorId String
  companyId String?
  mode ProjectMode @default(SINGLE)
  status ProjectStatus @default(WAITING_FOR_FORM)
  formResponses Json?
  formId String?
  items ProjectItem[]
  chatMessages ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  initialAnalysis String? @db.Text 
  riskAnalysis String? @db.Text    
  finalAnalysis String? @db.Text
  ratings           ProjectRatingHistory[]
  feedbackRequests  ProjectFeedbackRequest[]
  accesses          ProjectAccess[] 
  goals ProjectGoal[]
  @@index([status])
  @@index([companyId])
}

model ProjectRatingHistory {
  id String @id @default(uuid())
  projectId String
  raterId String 
  score Int
  comment String?
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rater User @relation(fields: [raterId], references: [id]) 
  @@unique([projectId, raterId])
  @@index([projectId])
  @@index([raterId])
}

model ProjectItem {
  id String @id @default(uuid())
  projectId String
  formTitle String 
  analysis String @db.Text
  // ترتیب مراحل (۱، ۲، ۳، ...)
  order Int 
  // آیا این مرحله نهایی است؟
  isFinal Boolean @default(false)
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([order])
}

model ChatMessage {
  id String @id @default(uuid())
  projectId String
  userId String?
  role String // "user" | "assistant" | "system"
  content String @db.Text 
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model AnalysisForm {
  id         String         @id @default(uuid())
  title      String
  info       String?
  order      Int?
  isActive   Boolean        @default(true)
  questions  FormQuestion[]
  prompts    FormPrompt[]
  goals      FormGoal[]
  stepFlowItems  StepFlowItem[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
}

model FormPrompt {
  id        String       @id @default(uuid())
  formId    String
  content   String       @db.Text
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  @@index([formId])
}

model FormGoal {
  id        String       @id @default(uuid())
  formId    String
  title     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  projects ProjectGoal[]
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model ProjectGoal {
  projectId String
  goalId    String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal      FormGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@id([projectId, goalId])
  @@index([goalId])
}

model FormQuestion {
  id       String       @id @default(uuid())
  formId   String
  label    String
  type     QuestionType
  options  Json?
  required Boolean      @default(true)
  order    Int

  form     AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

model StepSession {
  id          String            @id @default(uuid())
  userId      String
  flowId      String
  currentStep Int
  data        Json
  status      StepSessionStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow StepFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([flowId])
  @@index([status])
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StepFlowItem {
  id       String  @id @default(uuid())
  flowId   String
  formId   String
  order    Int
  required Boolean @default(true)
  flow StepFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  @@index([flowId, order])
}

model StepFlow {
  id        String   @id @default(uuid())
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  steps    StepFlowItem[]
  sessions StepSession[]
}

model ProjectFeedbackRequest {
  id String @id @default(uuid())
  projectId String
  userId String 
  adminResponseText String? 
  status FeedbackStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
  @@unique([projectId])
  @@index([status])
  @@index([userId])
}

model Notification {
  id String @id @default(uuid())
  userId String 
  type NotificationType
  title String 
  message String 
  isRead Boolean @default(false) 
  referenceId String? 
  referenceType String?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, isRead]) 
  @@index([createdAt])
}

model ProjectAccess {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  createdAt DateTime @default(now())
}