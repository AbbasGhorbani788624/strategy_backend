generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}


enum Role {
  SUPER_ADMIN
  COMPANY
  MEMBER
}

enum ProfileSection {
  BASIC
  FINANCIAL
  STRATEGY
  HR
  CONTACT
}

enum ProjectMode {
  SINGLE
  MULTI
}

enum ProjectStatus {
  WAITING_FOR_FORM
  ANALYSIS_PENDING
  REVIEWING
  CHAT_MODE
  RISK_ANALYSIS
  FINAL_ANALYSIS
}

enum NotificationType {
  ADMIN_FEEDBACK     
  PROJECT_RATED      
  PROJECT_ACCESS_GRANTED
  FOLLOW_UP_ANSWERED
}

enum QuestionType {
  CHECKBOX
  RADIO
  DROPDOWN
  TEXT
  TEXTAREA
  NUMBER
}

enum FollowUpStatus {
  PENDING
  ANSWERED
}

enum PromptOwnerType {
  ANALYSIS_FORM
  MULTI_ANALYSIS_FORM
}

enum PromptVersionStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model User {
  id               String   @id @default(uuid())
  avatar           String?
  username         String   @unique
  password         String
  email            String?  @unique
  phoneNumber      String?  @unique
  role             Role
  companyId        String?
  profile          Json?
  progress         Json?  

  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company         Company?      @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: Cascade)
  createdProjects Project[]
  ratingHistory   ProjectRatingHistory[]
  profileViewAccesses ProfileViewAccess[]
  chatMessages        ChatMessage[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  projectAccesses   ProjectAccess[] 
  followUpRequests FollowUpRequest[] @relation("UserFollowUpRequests")
  answeredFollowUps FollowUpRequest[] @relation("AdminAnsweredFollowUps")
  @@index([role])
  @@index([companyId])
}

model ProfileViewAccess {
  id        String         @id @default(uuid())
  userId    String
  companyId String
  section   ProfileSection
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([userId, section])
  @@index([companyId])
}

model Company {
  id                  String              @id @default(uuid())
  name                String              @unique
  industry            String?
  profile             Json?
  progress         Json?  
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userLimit           Int                 @default(1)
  members             User[]              @relation("CompanyMembers")
  projects            Project[]
  profileViewAccesses ProfileViewAccess[]
  adminData           CompanyAdminData?
  profileCompleted Boolean @default(false)
  @@index([id])
}

model CompanyAdminData {
  id        String   @id @default(uuid())
  companyId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Project {
  id String @id @default(uuid())
  title String
  creatorId String
  companyId String?
  mode ProjectMode @default(SINGLE)
  status ProjectStatus @default(WAITING_FOR_FORM)

  formResponses Json?
  formId String?
  multiAnalysisFormId String?

  promptVersionId String?

  chatMessages ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)

  form AnalysisForm? @relation(fields: [formId], references: [id], onDelete: SetNull)
  multiAnalysisForm MultiAnalysisForm? @relation(fields: [multiAnalysisFormId], references: [id], onDelete: SetNull)
  promptVersion PromptVersion? @relation(fields: [promptVersionId], references: [id], onDelete: SetNull)

  initialAnalysis String? @db.Text
  riskAnalysis String? @db.Text
  finalAnalysis String? @db.Text

  ratings ProjectRatingHistory[]
  accesses ProjectAccess[]
  goals ProjectGoal[]
  multiGoals ProjectMultiGoal[]
  followUpRequests FollowUpRequest[]

  averageRating Float @default(0)
  ratingCount Int @default(0)
  hasRating Boolean @default(false)

  chatModeStartedAt DateTime?
  chatModeEndedAt DateTime?

  selectedSourceProjects MultiAnalysisProjectSource[] @relation("MultiProjectSources")
  usedInMultiProjects MultiAnalysisProjectSource[] @relation("SourceProjectUsedInMulti")

  @@index([status])
  @@index([companyId])
  @@index([formId])
  @@index([multiAnalysisFormId])
  @@index([promptVersionId])
}

model ProjectRatingHistory {
  id String @id @default(uuid())
  projectId String
  raterId String 
  score Int
  comment String?
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rater User @relation(fields: [raterId], references: [id]) 
  @@unique([projectId, raterId])
  @@index([projectId])
  @@index([raterId])
}

model ChatMessage {
  id String @id @default(uuid())
  projectId String
  userId String?
  role String // "user" | "assistant" | "system"
  content String @db.Text 
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model AnalysisForm {
  id        String   @id @default(uuid())
  title     String
  info      String?
  order     Int?
  isActive  Boolean  @default(true)

  questions FormQuestion[]
  goals     FormGoal[]

  promptDefinition PromptDefinition?

  projects Project[]

  requiredInMultiAnalysis MultiAnalysisRequiredForm[]
  multiProjectSources     MultiAnalysisProjectSource[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model FormGoal {
  id        String       @id @default(uuid())
  formId    String
  title     String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  projects ProjectGoal[]
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model ProjectGoal {
  id        String   @id @default(uuid())
  projectId String
  goalId    String
  createdAt DateTime @default(now())

  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal      FormGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([projectId, goalId])
  @@index([projectId])
  @@index([goalId])
}

model FormQuestion {
  id       String       @id @default(uuid())
  formId   String
  label    String
  type     QuestionType
  options  Json?
  required Boolean      @default(true)
  order    Int

  form     AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id String @id @default(uuid())
  userId String 
  type NotificationType
  title String 
  message String 
  isRead Boolean @default(false) 
  referenceId String? 
  referenceType String?
  createdAt DateTime @default(now())
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, isRead]) 
  @@index([createdAt])
}

model ProjectAccess {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  createdAt DateTime @default(now())
}

model MultiAnalysisRequiredForm {
  id                  String @id @default(uuid())
  multiAnalysisFormId String
  formId              String
  order               Int

  multiAnalysisForm MultiAnalysisForm @relation(fields: [multiAnalysisFormId], references: [id], onDelete: Cascade)
  form              AnalysisForm      @relation(fields: [formId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([multiAnalysisFormId, formId])
  @@index([multiAnalysisFormId, order])
  @@index([formId])
}

model MultiAnalysisProjectSource {
  id              String @id @default(uuid())
  multiProjectId  String
  sourceProjectId String
  formId          String
  createdAt       DateTime @default(now())

  multiProject  Project      @relation("MultiProjectSources", fields: [multiProjectId], references: [id], onDelete: Cascade)
  sourceProject Project      @relation("SourceProjectUsedInMulti", fields: [sourceProjectId], references: [id], onDelete: Cascade)
  form          AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@unique([multiProjectId, formId])
  @@index([multiProjectId])
  @@index([sourceProjectId])
  @@index([formId])
}

model MultiAnalysisForm {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  order       Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  requiredForms MultiAnalysisRequiredForm[]
  goals         MultiAnalysisGoal[]
  projects      Project[]

  promptDefinition PromptDefinition?

  @@index([isActive])
  @@index([order])
}

model MultiAnalysisGoal {
  id                  String   @id @default(uuid())
  multiAnalysisFormId String
  title               String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  projects            ProjectMultiGoal[]
  multiAnalysisForm   MultiAnalysisForm @relation(fields: [multiAnalysisFormId], references: [id], onDelete: Cascade)


@@unique([multiAnalysisFormId, title])
  @@index([multiAnalysisFormId])
}

model ProjectMultiGoal {
  id        String   @id @default(uuid())
  projectId String
  goalId    String
  createdAt DateTime @default(now())

  project   Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  goal      MultiAnalysisGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@unique([projectId, goalId])
  @@index([projectId])
  @@index([goalId])
}

model FollowUpForm {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true)
  order       Int?

  questions   FollowUpFormQuestion[]
  requests    FollowUpRequest[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([order])
}

model FollowUpFormQuestion {
  id       String       @id @default(uuid())
  formId   String
  label    String
  type     QuestionType
  options  Json?
  required Boolean      @default(true)
  order    Int

  form     FollowUpForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])
}

model FollowUpRequest {
  id          String         @id @default(uuid())

  title       String
  status      FollowUpStatus @default(PENDING)

  projectId   String
  userId      String
  formId      String?

  responses   Json

  adminAnswer String?        @db.Text
  answeredAt  DateTime?
  answeredById String?

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  project     Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User           @relation("UserFollowUpRequests", fields: [userId], references: [id], onDelete: Cascade)
  form        FollowUpForm?  @relation(fields: [formId], references: [id], onDelete: SetNull)
  answeredBy  User?          @relation("AdminAnsweredFollowUps", fields: [answeredById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([formId])
  @@index([status])
  @@index([createdAt])
  @@index([title])
}

model PromptDefinition {
  id                  String   @id @default(uuid())
  ownerType           PromptOwnerType
  title               String?
  analysisFormId      String?  @unique
  multiAnalysisFormId String?  @unique

  analysisForm        AnalysisForm?      @relation(fields: [analysisFormId], references: [id])
  multiAnalysisForm   MultiAnalysisForm? @relation(fields: [multiAnalysisFormId], references: [id])

  segments            PromptSegmentDefinition[]
  versions            PromptVersion[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model PromptSegmentDefinition {
  id                 String   @id @default(uuid())
  promptDefinitionId String
  key                String
  label              String
  description        String?
  sortOrder          Int?
  isRequired         Boolean @default(false)

  promptDefinition   PromptDefinition @relation(fields: [promptDefinitionId], references: [id])
  values             PromptVersionSegmentValue[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([promptDefinitionId, key])
  @@index([promptDefinitionId, sortOrder])
}

model PromptVersion {
  id                 String   @id @default(uuid())
  promptDefinitionId String
  versionNumber      Int
  versionKey         String
  status             PromptVersionStatus
  publishedAt        DateTime?

  promptDefinition   PromptDefinition @relation(fields: [promptDefinitionId], references: [id])
  values             PromptVersionSegmentValue[]
  projects           Project[]

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([promptDefinitionId, versionNumber])
  @@unique([promptDefinitionId, versionKey])
}

model PromptVersionSegmentValue {
  id                  String   @id @default(uuid())
  promptVersionId     String
  segmentDefinitionId String
  content             String

  promptVersion       PromptVersion @relation(fields: [promptVersionId], references: [id])
  segmentDefinition   PromptSegmentDefinition @relation(fields: [segmentDefinitionId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([promptVersionId, segmentDefinitionId])
}
