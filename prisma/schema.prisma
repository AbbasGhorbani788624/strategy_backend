generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY
  MEMBER
}

enum ProfileSection {
  BASIC
  FINANCIAL
  STRATEGY
  HR
  CONTACT
}

enum ProjectMode {
  SINGLE
  STEP
}

enum Outcome {
  YES
  NO
}

enum StepSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

model User {
  id               String   @id @default(uuid())
  avatar           String?
  username         String   @unique
  fullname         String?
  email            String?  @unique
  phoneNumber      String?  @unique
  password         String
  role             Role
  companyId        String?
  profile          Json?
  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  company         Company?      @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: SetNull)
  createdProjects Project[]
  stepSessions    StepSession[]

  ratingHistory       ProjectRatingHistory[]
  profileViewAccesses ProfileViewAccess[]
  chatMessages        ChatMessage[]
  refreshTokens       RefreshToken[]

  @@index([role])
  @@index([companyId])
}

model ProfileViewAccess {
  id        String         @id @default(uuid())
  userId    String
  companyId String
  section   ProfileSection

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, section])
  @@index([companyId])
}

model Company {
  id                  String              @id @default(uuid())
  name                String              @unique
  industry            String?
  profile             Json? // پروفایل شرکت
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userLimit           Int                 @default(1)
  members             User[]              @relation("CompanyMembers") // کارکنان شرکت
  projects            Project[] // پروژه‌های شرکت و اعضا
  profileViewAccesses ProfileViewAccess[]
  adminData           CompanyAdminData?

  @@index([id]) // معمولاً primary key index خودکار
}

model CompanyAdminData {
  id        String   @id @default(uuid())
  companyId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Project {
  id        String      @id @default(uuid())
  title     String
  creatorId String
  companyId String?
  mode      ProjectMode
  outcome      Outcome?
  outcomeSetAt DateTime?
  solution     String? @db.Text
  ratedAt        DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  creator      User          @relation(fields: [creatorId], references: [id])
  company      Company?      @relation(fields: [companyId], references: [id])
  items        ProjectItem[]
  chatMessages ChatMessage[]

  projectRatingHistories ProjectRatingHistory[]

  @@index([companyId])
  @@index([creatorId])
}

model ProjectRatingHistory {
  id        String   @id @default(uuid())
  projectId String
  adminId   String
  score     Int
  comment   String?
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  admin   User    @relation(fields: [adminId], references: [id])

  @@unique([projectId, adminId])
  @@index([projectId])
  @@index([adminId])
  @@index([createdAt])
}

model ProjectItem {
  id        String  @id @default(uuid())
  projectId String
  formId    String
  formTitle String
  responses Json?
    //  داده‌های بصری (نمودار، جدول، چارت)
  visualData Json? 
  analysis  String @db.Text
  solution  String? @db.Text
  order     Int
  isFinal   Boolean @default(false)
  createdAt DateTime @default(now()) 
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId]) // سریع پیدا کردن آیتم‌های پروژه
  @@index([formId]) // سریع پیدا کردن آیتم‌های یک فرم خاص
  @@index([isFinal]) // برای تحلیل نهایی در STEP mode
  @@index([order]) // مرتب‌سازی مراحل در STEP mode
}

model ChatMessage {
  id        String  @id @default(uuid())
  projectId String
  userId    String?

  role      String // "user" | "assistant" | "system"
  content   String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model AnalysisForm {
  id             String         @id @default(uuid())
  title          String
  info           String?
  promptTemplate String
  order          Int?
  isActive       Boolean        @default(true)
  questions      FormQuestion[]
  stepFlowItems  StepFlowItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model FormQuestion {
  id       String       @id @default(uuid())
  formId   String
  label    String
  type     String
  options  Json?
  required Boolean      @default(true)
  order    Int
  form     AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order]) // مرتب‌سازی سوالات فرم
}

model StepSession {
  id          String            @id @default(uuid())
  userId      String
  flowId      String
  currentStep Int
  data        Json
  status      StepSessionStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow StepFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([flowId])
  @@index([status])
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt DateTime
  revoked   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StepFlowItem {
  id       String  @id @default(uuid())
  flowId   String
  formId   String
  order    Int
  required Boolean @default(true)

  flow StepFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([flowId, order])
}

model StepFlow {
  id        String   @id @default(uuid())
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  steps    StepFlowItem[]
  sessions StepSession[]
}
