generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
    url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY
  MEMBER
}

enum ProjectMode {
  SINGLE
  STEP
}

enum Outcome {
  YES
  NO
}

model User {
  id               String    @id @default(uuid())
  username         String    @unique
  password         String
  role             Role
  companyId        String?   // اگر MEMBER هست به کدام شرکت تعلق دارد
  profile          Json?
  profileCompleted Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company          Company?  @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: SetNull)
  createdProjects  Project[]
  stepSessions     StepSession[]

  @@index([role])        // جستجو بر اساس نقش، مثلاً همه MEMBER ها یا COMPANY ها
  @@index([companyId])   // جستجو اعضای یک شرکت سریع
}

model Company {
  id        String    @id @default(uuid())
  name      String
  industry  String?
  profile   Json?     // پروفایل شرکت
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  members   User[]    @relation("CompanyMembers") // کارکنان شرکت
  projects  Project[] // پروژه‌های شرکت و اعضا

  @@index([id])          // معمولاً primary key index خودکار
}

model Project {
  id           String       @id @default(uuid())
  title        String
  creatorId    String       // می‌تواند شرکت یا MEMBER باشد
  companyId    String?      // مرتبط با کدام شرکت است
  mode         ProjectMode
  outcome      Outcome?
  outcomeSetAt DateTime?
  solution     String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  creator      User         @relation(fields: [creatorId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  items        ProjectItem[]

  @@index([creatorId])   // این درست است
  @@index([companyId])   // سریع پیدا کردن پروژه‌های یک شرکت
  @@index([mode])        // اگر query روی نوع پروژه (SINGLE / STEP) داشته باشیم
  @@index([outcome])     // اگر بخواهیم پروژه‌هایی که YES/NO شدن پیدا کنیم
}

model ProjectItem {
  id        String    @id @default(uuid())
  projectId String
  formId    String
  formTitle String
  responses Json?
  analysis  String
  solution  String?
  order     Int
  isFinal   Boolean   @default(false)

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])   // سریع پیدا کردن آیتم‌های پروژه
  @@index([formId])      // سریع پیدا کردن آیتم‌های یک فرم خاص
  @@index([isFinal])     // برای تحلیل نهایی در STEP mode
  @@index([order])       // مرتب‌سازی مراحل در STEP mode
}

model FormCategory {
  id        String         @id @default(uuid())
  name      String         @unique
  description String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  forms     AnalysisForm[]

  @@index([isActive])
}

model AnalysisForm {
  id              String         @id @default(uuid())
  title           String
  info            String?
  promptTemplate  String
  order           Int?
  isActive        Boolean        @default(true)

  categoryId      String
  category        FormCategory   @relation(fields: [categoryId], references: [id])

  questions       FormQuestion[]
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([categoryId])
}

model FormQuestion {
  id          String       @id @default(uuid())
  formId      String
  label       String
  type        String
  options     Json?
  required    Boolean      @default(false)
  order       Int
  form        AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId, order])  // مرتب‌سازی سوالات فرم
}

model StepSession {
  id          String    @id @default(uuid())
  userId      String
  currentStep Int
  data        Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])      // پیدا کردن session های کاربر
}