generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  COMPANY
  MEMBER
}

enum ProfileSection {
  BASIC
  FINANCIAL
  STRATEGY
  HR
  CONTACT
}

enum ProjectMode {
  SINGLE
  STEP
}

enum ProjectStatus {
  DRAFT           // پروژه ساخته شده، آماده شروع
  REVIEWING       // فرضیات آماده، منتظر تایید/رد کاربر
  CHAT_MODE       // در حال گفتگو برای شفاف‌سازی (پس از رد فرضیات)
  RISK_ANALYSIS   // تحلیل ریسک آماده، منتظر تایید برای نهایی
  FINAL_ANALYSIS  // تحلیل نهایی آماده
}

enum Outcome {
  YES
  NO
}

enum StepSessionStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum FeedbackStatus {
  PENDING   
  REVIEWED   
}

enum NotificationType {
  ADMIN_FEEDBACK      // پاسخ ادمین به درخواست بازخورد کاربر
  PROJECT_RATED       // وقتی کسی پروژه شما را ریت کرد 
  PROJECT_ACCESS_GRANTED      
}


model User {
  id               String   @id @default(uuid())
  avatar           String?
  username         String   @unique
  fullname         String?
  email            String?  @unique
  phoneNumber      String?  @unique
  password         String
  role             Role
  companyId        String?
  profile          Json?
  profileCompleted Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  company         Company?      @relation("CompanyMembers", fields: [companyId], references: [id], onDelete: Cascade)
  createdProjects Project[]
  stepSessions    StepSession[]
  ratingHistory   ProjectRatingHistory[]
  profileViewAccesses ProfileViewAccess[]
  chatMessages        ChatMessage[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
  feedbackRequests    ProjectFeedbackRequest[]

  @@index([role])
  @@index([companyId])
}

model ProfileViewAccess {
  id        String         @id @default(uuid())
  userId    String
  companyId String
  section   ProfileSection
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  @@unique([userId, section])
  @@index([companyId])
}

model Company {
  id                  String              @id @default(uuid())
  name                String              @unique
  industry            String?
  profile             Json? // پروفایل شرکت
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  userLimit           Int                 @default(1)
  members             User[]              @relation("CompanyMembers") // کارکنان شرکت
  projects            Project[] // پروژه‌های شرکت و اعضا
  profileViewAccesses ProfileViewAccess[]
  adminData           CompanyAdminData?
  @@index([id]) // معمولاً primary key index خودکار
}

model CompanyAdminData {
  id        String   @id @default(uuid())
  companyId String   @unique
  data      Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Project {
  id String @id @default(uuid())
  title String
  creatorId String
  companyId String?
  mode ProjectMode @default(SINGLE)
  status ProjectStatus @default(DRAFT)
  formResponses Json?
  formId String?
  items ProjectItem[]
  chatMessages ChatMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  allowedViewerIds Json?
  creator User @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  initialAnalysis String? @db.Text 
  riskAnalysis String? @db.Text    
  finalAnalysis String? @db.Text
  ratings           ProjectRatingHistory[]
  feedbackRequests  ProjectFeedbackRequest[]

  @@index([status])
  @@index([companyId])
}

model ProjectRatingHistory {
  id String @id @default(uuid())
  projectId String
  raterId String // کسی که امتیاز داده (ریتِر)
  score Int
  comment String?
  createdAt DateTime @default(now())
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rater User @relation(fields: [raterId], references: [id]) // رابطه با کاربر ریتِر
  
  
  // اطمینان از اینکه یک نفر فقط یک بار به یک پروژه امتیاز می‌دهد
  @@unique([projectId, raterId])
  @@index([projectId])
  @@index([raterId])
}

model ProjectItem {
  id String @id @default(uuid())
  projectId String
  
  formTitle String 
  
  analysis String @db.Text
  
  // ترتیب مراحل (۱، ۲، ۳، ...)
  order Int 
  
  // آیا این مرحله نهایی است؟
  isFinal Boolean @default(false)
  
  createdAt DateTime @default(now())
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([order])
}

model ChatMessage {
  id String @id @default(uuid())
  projectId String
  userId String?
  role String // "user" | "assistant" | "system"
  content String @db.Text 
  createdAt DateTime @default(now())
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([projectId])
  @@index([userId])
  @@index([createdAt])
}

model AnalysisForm {
  id             String         @id @default(uuid())
  title          String
  info           String?
  promptTemplate String
  order          Int?
  isActive       Boolean        @default(true)
  questions      FormQuestion[]
  stepFlowItems  StepFlowItem[]
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

model FormQuestion {
  id       String       @id @default(uuid())
  formId   String
  label    String
  type     String
  options  Json?
  required Boolean      @default(true)
  order    Int
  form     AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  @@index([formId, order]) // مرتب‌سازی سوالات فرم
}

model StepSession {
  id          String            @id @default(uuid())
  userId      String
  flowId      String
  currentStep Int
  data        Json
  status      StepSessionStatus @default(ACTIVE)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  flow StepFlow @relation(fields: [flowId], references: [id], onDelete: Cascade)
  @@index([userId])
  @@index([flowId])
  @@index([status])
}

model RefreshToken {
  id        String @id @default(uuid())
  tokenHash String @unique
  userId    String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StepFlowItem {
  id       String  @id @default(uuid())
  flowId   String
  formId   String
  order    Int
  required Boolean @default(true)
  flow StepFlow     @relation(fields: [flowId], references: [id], onDelete: Cascade)
  form AnalysisForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  @@index([flowId, order])
}

model StepFlow {
  id        String   @id @default(uuid())
  title     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  steps    StepFlowItem[]
  sessions StepSession[]
}

model ProjectFeedbackRequest {
  id String @id @default(uuid())
  projectId String
  userId String 
  adminResponseText String? // متنی که ادمین پاسخ می‌دهد
  status FeedbackStatus @default(PENDING)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id])
  
  // اطمینان از اینکه برای یک پروژه خاص، فقط یک درخواست بازخورد فعال وجود دارد
  @@unique([projectId])
  @@index([status])
  @@index([userId])
}

model Notification {
  id String @id @default(uuid())
  userId String 
  type NotificationType
  title String 
  message String 
  isRead Boolean @default(false) 
  referenceId String? 
  referenceType String?
  createdAt DateTime @default(now())
  
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId, isRead]) 
  @@index([createdAt])
}